# .env.example
# Environment variables for the RightRoute platform.
# Replace placeholder values with your actual credentials.

# --- Core Application Settings ---
NEXT_PUBLIC_APP_NAME="RightRoute"
NEXT_PUBLIC_APP_URL="http://localhost:3000" # Your deployed app URL (e.g., https://rightroute.vercel.app)
NEXT_PUBLIC_NODE_ENV="development" # development, production

# --- Supabase Configuration (Free Tier, then Scale) ---
# Find these in your Supabase Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL="YOUR_SUPABASE_PROJECT_URL" # e.g., https://abcde12345.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_KEY" # Public key, safe to use in frontend
SUPABASE_URL="YOUR_SUPABASE_PROJECT_URL"
SUPABASE_SERVICE_ROLE_KEY="YOUR_SUPABASE_SERVICE_ROLE_KEY" # Secret key, ONLY use in backend
DATABASE_URL="postgresql://postgres:YOUR_DB_PASSWORD@db.abcde12345.supabase.co:5432/postgres" # Full database connection string for Prisma

# --- Map Services (Leaflet/OpenStreetMap + Mapbox GL JS) ---
# OpenStreetMap is free and doesn't require keys for basic tile serving.
# Mapbox for advanced routing and live tracking.
NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN="YOUR_MAPBOX_PUBLIC_ACCESS_TOKEN" # Public token for frontend
MAPBOX_SECRET_TOKEN="YOUR_MAPBOX_SECRET_TOKEN" # Secret token for backend API calls

# --- SMS OTP & Notifications (Africa's Talking / Termii) ---
# Choose one provider and configure accordingly.
AFRICAS_TALKING_USERNAME="YOUR_AT_USERNAME"
AFRICAS_TALKING_API_KEY="YOUR_AT_API_KEY"
AFRICAS_TALKING_SENDER_ID="RightRoute"

# Termii (Alternative/Fallback)
TERMII_API_KEY="YOUR_TERMII_API_KEY"
TERMII_SENDER_ID="RightRoute"
TERMII_CHANNEL="dnd"

# --- Payment Gateways (Flutterwave, MTN MoMo, Airtel Money) ---
# Flutterwave (Rave) - for broader card/bank payments
NEXT_PUBLIC_FLUTTERWAVE_PUBLIC_KEY="YOUR_FLUTTERWAVE_PUBLIC_KEY"
FLUTTERWAVE_SECRET_KEY="YOUR_FLUTTERWAVE_SECRET_KEY"
FLUTTERWAVE_ENCRYPTION_KEY="YOUR_FLUTTERWAVE_ENCRYPTION_KEY"

# MTN Mobile Money (Uganda Specific)
MTN_MOMO_API_KEY="YOUR_MTN_MOMO_API_KEY"
MTN_MOMO_PRIMARY_CALLBACK_URL="YOUR_APP_URL/api/payments/mtnmomo/callback"
MTN_MOMO_FINANCIAL_CALLBACK_URL="YOUR_APP_URL/api/payments/mtnmomo/financial-callback"

# Airtel Money (Uganda Specific)
AIRTEL_MONEY_API_KEY="YOUR_AIRTEL_MONEY_API_KEY"
AIRTEL_MONEY_CALLBACK_URL="YOUR_APP_URL/api/payments/airtelmoney/callback"

# --- Real-time Fallback (Pusher) ---
NEXT_PUBLIC_PUSHER_APP_KEY="YOUR_PUSHER_APP_KEY"
PUSHER_APP_ID="YOUR_PUSHER_APP_ID"
PUSHER_SECRET="YOUR_PUSHER_SECRET"
NEXT_PUBLIC_PUSHER_CLUSTER="YOUR_PUSHER_CLUSTER"

# --- Optional: WhatsApp Business API ---
WHATSAPP_API_TOKEN="YOUR_WHATSAPP_API_TOKEN"
WHATSAPP_SENDER_PHONE_NUMBER="YOUR_WHATSAPP_SENDER_PHONE_NUMBER"

# --- Advanced Caching/Queueing (Placeholders for Scalability) ---
REDIS_URL="YOUR_REDIS_CONNECTION_STRING"
REDIS_CACHE_TTL_SECONDS="3600"
BULLMQ_REDIS_URL="YOUR_BULLMQ_REDIS_URL"
